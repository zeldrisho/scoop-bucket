    "notes": "Register service by running: $dir\\service.ps1",
    "architecture": {
        "64bit": {
            "url": "https://vpn.protondownload.com/download/ProtonVPN_v5.1.5_x64.exe",
            "hash": "1e6600e45c0684d0faa7f040208603b72a0f7b1468b682c1007a31972cba1d9c"
        },
        "arm64": {
            "url": "https://vpn.protondownload.com/download/ProtonVPN_v5.1.5_arm64.exe",
            "hash": "32b43381b9e533c091e1df58f823e30e871b7f818ef417f2e3fea2d4de24407a"
        }
    },
    "innosetup": true,
    "post_install": [
        "New-Item \"$dir\\version\" -ItemType Junction -Target \"$dir\\v$version\" | Out-Null",
        "Copy-Item \"$bucketsdir\\$bucket\\scripts\\$app\\service.ps1\" \"$dir\"",
        "$shortcut = \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\Proton\\Proton VPN.lnk\"",
        "$bytes = [System.IO.File]::ReadAllBytes($shortcut)",
        "$bytes[0x15] = $bytes[0x15] -bor 0x20",
        "[System.IO.File]::WriteAllBytes($shortcut, $bytes)"
    ],
    "shortcuts": [
        [
            "ProtonVPN.Launcher.exe",
            "Proton\\Proton VPN"
        ]
    ],
    "persist": "version\\ServiceData",
    "checkver": {
        "url": "https://protonvpn.com/download/windows/x64/v1/version.json",
        "jsonpath": "$..[?(@.CategoryName == 'Stable')].Version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://vpn.protondownload.com/download/ProtonVPN_v$version_x64.exe"
            },
            "arm64": {
