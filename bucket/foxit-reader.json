{
    "version": "2026.1.0.36452",
    "description": "Free PDF reader & viewer",
    "homepage": "https://foxit.com/pdf-reader",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://cdn01.foxitsoftware.com/product/reader/desktop/win/2026.1.0/FoxitPDFReader20261_L10N_Setup_Prom_x64.exe",
            "hash": "190503fa044aed47b9f4b610dce25831cf12549eba20302ad35a152807c4e0ec"
        },
        "32bit": {
            "url": "https://cdn01.foxitsoftware.com/product/reader/desktop/win/2026.1.0/FoxitPDFReader20261_L10N_Setup_Prom_x86.exe",
            "hash": "26126bbdd229a2df047f5f9c5071ef118601375e6d82d8fd17e3847c3349ee4a"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\$fname\" -ExtractDir '.rsrc\\1033\\PAYLOAD' -DestinationPath \"$dir\\msi\" -Removal",
        "$succ = Invoke-ExternalCommand msiexec -ArgumentList @('/a', \"$dir\\msi\\500\", '/p', \"$dir\\msi\\700\", '/qn', \"TARGETDIR=$dir\\extracted\") -LogPath \"$dir\\install.log\"",
        "if(-not $succ) {",
        "    error \"Failed to extract files from `\"$dir\\msi`\".`nLog file:`n  $(friendly_path `\"$dir\\install.log`\")`n$(new_issue_msg $app $bucket 'decompress error')\"",
        "    break",
        "}",
        "Move-Item \"$dir\\extracted\\Foxit Software\\Foxit PDF Reader\\*\" \"$dir\""
    ],
    "post_install": "Remove-Item \"$dir\\msi\", \"$dir\\extracted\", \"$dir\\install.log\" -Recurse -Force",
    "shortcuts": [
        [
            "FoxitPDFReader.exe",
            "Foxit PDF Reader"
        ]
    ],
    "checkver": {
        "url": "https://foxit.com/pdf-reader/version-history",
        "regex": "Version ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn01.foxitsoftware.com/product/reader/desktop/win/$matchHead/FoxitPDFReader$majorVersion$minorVersion_L10N_Setup_Prom_x64.exe"
            },
            "32bit": {
                "url": "https://cdn01.foxitsoftware.com/product/reader/desktop/win/$matchHead/FoxitPDFReader$majorVersion$minorVersion_L10N_Setup_Prom_x86.exe"
            }
        }
    }
}
