{
    "version": "10.0.8",
    "description": ".NET Desktop Runtime enables you to run existing Windows desktop applications",
    "homepage": "https://dotnet.microsoft.com/download/dotnet",
    "license": "MIT",
    "notes": "You can now remove this installer by running: scoop uninstall windowsdesktop-runtime-lts",
    "architecture": {
        "64bit": {
            "url": "https://builds.dotnet.microsoft.com/dotnet/WindowsDesktop/10.0.8/windowsdesktop-runtime-10.0.8-win-x64.exe",
            "hash": "378866ddbc70116f0b83e88d1f7861271172813b5f7d8a59bf12fc992bf65786"
        },
        "32bit": {
            "url": "https://builds.dotnet.microsoft.com/dotnet/WindowsDesktop/10.0.8/windowsdesktop-runtime-10.0.8-win-x86.exe",
            "hash": "1e56a6d0005cfd7342911f54e06ff38344e134768883c0bd042146bb7d718e95"
        },
        "arm64": {
            "url": "https://builds.dotnet.microsoft.com/dotnet/WindowsDesktop/10.0.8/windowsdesktop-runtime-10.0.8-win-arm64.exe",
            "hash": "956f73a3a17b549acc55ffb694f8aeb82ff8ccdba8eee263a6a9195577dd8733"
        }
    },
    "pre_install": [
        "if (!(is_admin)) { \"$app requires admin rights to $cmd\"; break }",
        "Start-Process \"$dir\\$fname\" -ArgumentList @('/install', '/quiet', '/norestart') -Wait -Verb RunAs"
    ],
    "post_install": "Remove-Item \"$dir\\$fname\"",
    "checkver": {
        "url": "https://builds.dotnet.microsoft.com/dotnet/WindowsDesktop/LTS/latest.version",
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://builds.dotnet.microsoft.com/dotnet/WindowsDesktop/$version/windowsdesktop-runtime-$version-win-x64.exe"
            },
            "32bit": {
                "url": "https://builds.dotnet.microsoft.com/dotnet/WindowsDesktop/$version/windowsdesktop-runtime-$version-win-x86.exe"
            },
            "arm64": {
                "url": "https://builds.dotnet.microsoft.com/dotnet/WindowsDesktop/$version/windowsdesktop-runtime-$version-win-arm64.exe"
            }
        }
    }
}
