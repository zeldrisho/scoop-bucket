{
    "version": "10.0.8",
    "description": ".NET Runtime contains just the components needed to run a console app",
    "homepage": "https://dotnet.microsoft.com/download/dotnet",
    "license": "MIT",
    "notes": "You can now remove this installer by running: scoop uninstall dotnet-runtime-lts",
    "architecture": {
        "64bit": {
            "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/10.0.8/dotnet-runtime-10.0.8-win-x64.exe",
            "hash": "f8f6127cfe88f861217353ae3915830488effdd1ba2fe629c127d06533e83556"
        },
        "32bit": {
            "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/10.0.8/dotnet-runtime-10.0.8-win-x86.exe",
            "hash": "71de4e3f272434a18e0195d33878ab7b2108a656162d629079e5284b33eb53b5"
        },
        "arm64": {
            "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/10.0.8/dotnet-runtime-10.0.8-win-arm64.exe",
            "hash": "da593441a3eb0c857cf30918161671b534c6f1a2e5bf8ed2c52dbe7c89f7bf48"
        }
    },
    "pre_install": [
        "if (!(is_admin)) { \"$app requires admin rights to $cmd\"; break }",
        "Start-Process \"$dir\\$fname\" -ArgumentList @('/install', '/quiet', '/norestart') -Wait -Verb RunAs"
    ],
    "post_install": "Remove-Item \"$dir\\$fname\"",
    "checkver": {
        "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/LTS/latest.version",
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/$version/dotnet-runtime-$version-win-x64.exe"
            },
            "32bit": {
                "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/$version/dotnet-runtime-$version-win-x86.exe"
            },
            "arm64": {
                "url": "https://builds.dotnet.microsoft.com/dotnet/Runtime/$version/dotnet-runtime-$version-win-arm64.exe"
            }
        }
    }
}
