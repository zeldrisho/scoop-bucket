{
    "version": "6.7.0",
    "description": "VPN & all-in-one cybersecurity suites",
    "homepage": "https://surfshark.com",
    "license": "Proprietary",
    "notes": "Register service by running: $dir\\service.ps1",
    "architecture": {
        "64bit": {
            "url": "https://downloads.surfshark.com/windows/stable64/6.7.0.999/SurfsharkSetup.exe",
            "hash": "6b234e8a3c605b12bd68327264b77a2657909fac8546b7ffdd43b1add41956e0"
        },
        "arm64": {
            "url": "https://downloads.surfshark.com/windows/stable64/6.7.0.999/arm64/SurfsharkSetup.exe",
            "hash": "341125e119d1e4772595a83b9c9e15a3f27a683935e7ea4f332126a1313f5a48"
        }
    },
    "pre_install": [
        "if (!(is_admin)) { \"$app requires admin rights to $cmd\"; break }",
        "Start-Process \"$dir\\$fname\" -ArgumentList @('/extract', \"$dir\") -Wait -Verb RunAs",
        "Get-ChildItem \"$dir\" -Directory | ForEach-Object { Move-Item \"$_\\*\" \"$dir\"; Remove-Item $_ -Force }"
    ],
    "post_install": [
        "Remove-Item \"$dir\\$fname\"",
        "Copy-Item \"$bucketsdir\\$bucket\\scripts\\$app\\service.ps1\" \"$dir\""
    ],
    "shortcuts": [
        [
            "Surfshark.exe",
            "Surfshark"
        ]
    ],
    "post_uninstall": "Remove-Item \"$env:PUBLIC\\Desktop\\Surfshark.lnk\" -ErrorAction SilentlyContinue",
    "checkver": {
        "url": "https://downloads.surfshark.com/windows/stable64/meta/windows-changelog.txt",
        "regex": "Surfshark ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.surfshark.com/windows/stable64/$version.999/SurfsharkSetup.exe"
            },
            "arm64": {
                "url": "https://downloads.surfshark.com/windows/stable64/$version.999/arm64/SurfsharkSetup.exe"
            }
        }
    }
}
