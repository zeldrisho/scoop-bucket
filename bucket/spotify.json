{
    "version": "1.2.85.519",
    "description": "Play millions of songs and podcasts on your device",
    "homepage": "https://spotify.com",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://upgrade.scdn.co/upgrade/client/win32-x86_64/spotify_installer-1.2.85.519.g549a528b-4062.exe",
            "hash": "3546bf93d3bf0f2996f85adc69ede39b767c1effe187d488cbf377ba5662417a"
        },
        "arm64": {
            "url": "https://upgrade.scdn.co/upgrade/client/win32-arm64/spotify_installer-1.2.85.519.g549a528b-4019.exe",
            "hash": "f6847a26e2e02394a13d5ffb8cb6349520138ca11bb43a5895dd95befc1ed398"
        }
    },
    "pre_install": [
        "Start-Process \"$dir\\$fname\" -ArgumentList @('/extract', \"$dir\") -Wait",
        "$update = \"$env:LOCALAPPDATA\\Spotify\\Update\"",
        "Remove-Item $update -Recurse -Force -ErrorAction SilentlyContinue",
        "New-Item $update | Out-Null",
        "Set-ItemProperty $update -Name IsReadOnly -Value $true",
        "$Ace = New-Object System.Security.AccessControl.FileSystemAccessRule(\"${env:USERNAME}\", \"Modify\", \"Deny\")",
        "$Acl = New-Object System.Security.AccessControl.FileSecurity",
        "$Acl.AddAccessRule($Ace)",
        "Set-Acl $update -AclObject $Acl"
    ],
    "post_install": "Remove-Item \"$dir\\$fname\"",
    "shortcuts": [
        [
            "Spotify.exe",
            "Spotify"
        ]
    ],
    "checkver": {
        "url": "https://raw.githubusercontent.com/amd64fox/LoaderSpot/main/versions.json",
        "jsonpath": "$..[?(@.buildType == 'Release')]",
        "regex": "(?<version>[\\d.]+)\\.(?<build>[\\w]+)-(?<x64>[\\d]+).exe[\\s\\S]*?(?<arm>[\\d]+).exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://upgrade.scdn.co/upgrade/client/win32-x86_64/spotify_installer-$matchVersion.$matchBuild-$matchX64.exe"
            },
            "arm64": {
                "url": "https://upgrade.scdn.co/upgrade/client/win32-arm64/spotify_installer-$matchVersion.$matchBuild-$matchArm.exe"
            }
        }
    }
}
