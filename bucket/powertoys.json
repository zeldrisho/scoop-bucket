{
    "version": "0.99.0",
    "description": "Windows Utilities for Power Users",
    "homepage": "https://learn.microsoft.com/windows/powertoys",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/microsoft/PowerToys/releases/download/v0.99.0/PowerToysUserSetup-0.99.0-x64.exe",
            "hash": "1e3586a2ecd454b86fe61c44b003e0027fcc24dcb5135958b73d04a58285618c"
        },
        "arm64": {
            "url": "https://github.com/microsoft/PowerToys/releases/download/v0.99.0/PowerToysUserSetup-0.99.0-arm64.exe",
            "hash": "2bca2a1edb0077faf752dde95c8d02a0a7a70f8e5128f43ea58432bbbe4e3c62"
        }
    },
    "pre_install": [
        "Expand-DarkArchive \"$dir\\$fname\" \"$dir\\tmp\" -Removal",
        "$msi = Get-ChildItem \"$dir\\tmp\\AttachedContainer\\*.msi\" | Select-Object -First 1",
        "Expand-MsiArchive $msi -ExtractDir 'LocalApp\\PowerToys' -DestinationPath \"$dir\""
    ],
    "post_install": "Remove-Item \"$dir\\tmp\" -Recurse -Force",
    "shortcuts": [
        [
            "PowerToys.exe",
            "PowerToys"
        ]
    ],
    "checkver": {
        "github": "https://github.com/microsoft/PowerToys"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/microsoft/PowerToys/releases/download/v$version/PowerToysUserSetup-$version-x64.exe"
            },
            "arm64": {
                "url": "https://github.com/microsoft/PowerToys/releases/download/v$version/PowerToysUserSetup-$version-arm64.exe"
            }
        }
    }
}
